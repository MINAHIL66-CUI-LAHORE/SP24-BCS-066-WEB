<%- include('partials/header') %>

<section class="products" style="padding-top: 120px; max-width: 800px;">
  <a href="/products" class="see-all" style="display:inline-flex;margin-bottom:24px;">← All Products</a>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:start;">
    <% if (product.image) { %>
      <img src="/<%= product.image %>" alt="<%= product.alt %>"
           style="width:100%;border-radius:4px;background:#f5f5f5;"/>
    <% } %>
    <div>
      <p class="product-card__label"><%= product.label %></p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:48px;font-weight:900;text-transform:uppercase;margin-bottom:16px;">
        <%= product.name %>
      </h2>

      <% if (product.colors && product.colors.length) { %>
        <div class="product-card__colors" style="margin-bottom:20px;">
          <% product.colors.forEach(function(c) { %>
            <span class="swatch" style="background:<%= c %>;width:24px;height:24px;"></span>
          <% }) %>
        </div>
      <% } %>

      <div class="product-card__price" style="margin-bottom:24px;">
        <% if (product.salePrice) { %>
          <span class="price--sale" style="font-size:24px;"><%= product.salePrice %></span>
          <span class="price--orig"><%= product.origPrice %></span>
        <% } else { %>
          <span class="price--current" style="font-size:24px;"><%= product.price %></span>
        <% } %>
      </div>

      <button class="btn btn--black" style="width:100%;padding:18px;">Add to Cart</button>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
